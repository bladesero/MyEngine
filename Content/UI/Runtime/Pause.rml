<rml><head><title>Pause</title><style>
body{margin:0;width:100%;height:100%;font-family:LatoLatin;color:#f5f7fa}#runtime-root{position:absolute;left:0;top:0;width:100%;height:100%;background-color:rgba(5,8,14,190);z-index:2147470000}#runtime-card{position:absolute;left:30%;top:18%;width:40%;padding:24px;background-color:rgba(20,27,39,245);border:2px #52647d}#runtime-title{text-align:center;font-size:32px;margin-bottom:14px}.runtime-action{display:block;margin:5px;padding:9px;text-align:center;font-size:19px;background-color:#273244;border:2px #273244}.runtime-action.focused{background-color:#315d84;border-color:#8fd0ff}
</style></head><body><div id="runtime-root"><div id="runtime-card"><div id="runtime-title"></div><div id="runtime-action-resume" class="runtime-action"></div><div id="runtime-action-settings" class="runtime-action"></div><div id="runtime-action-mainMenu" class="runtime-action"></div><div id="runtime-input-hint" style="text-align:center;margin-top:10px;color:#9fb0c6"></div></div></div></body></rml>
