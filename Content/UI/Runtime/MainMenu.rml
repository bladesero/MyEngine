<rml><head><title>Main Menu</title><style>
body{margin:0;width:100%;height:100%;font-family:LatoLatin;color:#f5f7fa}#runtime-root{position:absolute;left:0;top:0;width:100%;height:100%;background-color:rgba(5,8,14,220);z-index:2147470000}#runtime-card{position:absolute;left:25%;top:20%;width:50%;padding:26px;background-color:rgba(20,27,39,245);border:2px #52647d}#runtime-title{text-align:center;font-size:36px;margin-bottom:18px}.runtime-action{display:block;margin:6px;padding:10px;text-align:center;font-size:20px;background-color:#273244;border:2px #273244}.runtime-action.focused{background-color:#315d84;border-color:#8fd0ff}
</style></head><body><div id="runtime-root"><div id="runtime-card"><div id="runtime-title"></div><div id="runtime-action-play" class="runtime-action"></div><div id="runtime-action-settings" class="runtime-action"></div><div id="runtime-input-hint" style="text-align:center;margin-top:10px;color:#9fb0c6"></div></div></div></body></rml>
