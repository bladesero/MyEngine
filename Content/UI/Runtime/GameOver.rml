<rml><head><title>Game Over</title><style>
body{margin:0;width:100%;height:100%;font-family:LatoLatin;color:#f5f7fa}#runtime-root{position:absolute;left:0;top:0;width:100%;height:100%;background-color:rgba(18,3,5,220);z-index:2147470000}#runtime-card{position:absolute;left:30%;top:24%;width:40%;padding:24px;background-color:rgba(35,18,22,245);border:2px #9b4d59}#runtime-title{text-align:center;font-size:34px;margin-bottom:14px}.runtime-action{display:block;margin:5px;padding:9px;text-align:center;font-size:19px;background-color:#44272d;border:2px #44272d}.runtime-action.focused{background-color:#7a3542;border-color:#ffb0bd}
</style></head><body><div id="runtime-root"><div id="runtime-card"><div id="runtime-title"></div><div id="runtime-action-retry" class="runtime-action"></div><div id="runtime-action-mainMenu" class="runtime-action"></div><div id="runtime-input-hint" style="text-align:center;margin-top:10px;color:#9fb0c6"></div></div></div></body></rml>
