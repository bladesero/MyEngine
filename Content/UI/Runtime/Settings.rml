<rml><head><title>Settings</title><style>
body{margin:0;width:100%;height:100%;font-family:LatoLatin;color:#f5f7fa}#runtime-root{position:absolute;left:0;top:0;width:100%;height:100%;background-color:rgba(5,8,14,220);z-index:2147470000}#runtime-card{position:absolute;left:18%;top:5%;width:64%;padding:16px;background-color:rgba(20,27,39,248);border:2px #52647d}#runtime-title{text-align:center;font-size:28px;margin-bottom:8px}.runtime-action{display:inline-block;width:42%;margin:2px 1%;padding:5px;text-align:center;font-size:15px;background-color:#273244;border:2px #273244}.runtime-action.focused{background-color:#315d84;border-color:#8fd0ff}
</style></head><body><div id="runtime-root"><div id="runtime-card"><div id="runtime-title"></div><div id="runtime-action-masterDown" class="runtime-action"></div><div id="runtime-action-masterUp" class="runtime-action"></div><div id="runtime-action-musicDown" class="runtime-action"></div><div id="runtime-action-musicUp" class="runtime-action"></div><div id="runtime-action-effectsDown" class="runtime-action"></div><div id="runtime-action-effectsUp" class="runtime-action"></div><div id="runtime-action-voiceDown" class="runtime-action"></div><div id="runtime-action-voiceUp" class="runtime-action"></div><div id="runtime-action-uiScaleDown" class="runtime-action"></div><div id="runtime-action-uiScaleUp" class="runtime-action"></div><div id="runtime-action-subtitles" class="runtime-action"></div><div id="runtime-action-highContrast" class="runtime-action"></div><div id="runtime-action-back" class="runtime-action"></div><div id="runtime-input-hint" style="text-align:center;margin-top:6px;color:#9fb0c6"></div></div></div></body></rml>
